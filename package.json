{
  "name": "svara",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source, local-first voice dictation for any app. A free alternative to Wispr Flow.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "bench": "cd src-tauri && cargo run --release --example bench_pipeline -- --wav ../benchmarks/fixtures/silence_3s.wav --n 10",
    "bench:tone": "cd src-tauri && cargo run --release --example bench_pipeline -- --wav ../benchmarks/fixtures/tone_440_2s.wav --n 10",
    "bench:no-ollama": "cd src-tauri && cargo run --release --example bench_pipeline -- --wav ../benchmarks/fixtures/silence_3s.wav --n 10 --no-ollama"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-log": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
